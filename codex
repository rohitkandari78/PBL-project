#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// ---------------- USER STRUCT ----------------
struct User {
    char name[50];
    int age;
    float weight;
    float height;
};

// ---------------- FITNESS STRUCT ----------------
struct Fitness {
    int steps;
    float caloriesConsumed;
    float caloriesBurned;
    float waterIntake;
    float sleepHours;
    int exerciseMinutes;
};

// ---------------- FUNCTION DECLARATIONS ----------------
float calculateCaloriesBurned(int steps, float weight);
float calculateBMI(float weight, float height);
void displayBMICategory(float bmi);
void displaySummary(struct User u, struct Fitness f);
void saveToFile(struct User u, struct Fitness f);
void viewHistory();
void resetData(struct Fitness *f);
void setGoals(int *stepGoal, float *waterGoal);
void weeklyStats();
void login();
void checkGoals(struct Fitness f, int stepGoal, float waterGoal);

// ---------------- CALCULATE CALORIES ----------------
float calculateCaloriesBurned(int steps, float weight) {
    return steps * 0.04 * (weight / 70.0);
}

// ---------------- BMI ----------------
float calculateBMI(float weight, float height) {
    if (height <= 0) return 0;
    return weight / (height * height);
}

// ---------------- BMI CATEGORY ----------------
void displayBMICategory(float bmi) {
    printf("BMI: %.2f\n", bmi);
if (bmi < 18.5)
        printf("Category: Underweight\n");
    else if (bmi < 25)
        printf("Category: Normal\n");
    else if (bmi < 30)
        printf("Category: Overweight\n");
    else
        printf("Category: Obese\n");
}


// ---------------- SUMMARY ----------------
void displaySummary(struct User u, struct Fitness f) {
    printf("\n===== SUMMARY =====\n");
    printf("Name: %s\n", u.name);
    printf("Age: %d\n", u.age);

    float bmi = calculateBMI(u.weight, u.height);
    displayBMICategory(bmi);

    printf("Steps: %d\n", f.steps);
    printf("Calories Consumed: %.2f kcal\n", f.caloriesConsumed);
    printf("Calories Burned: %.2f kcal\n", f.caloriesBurned);
    printf("Water Intake: %.2f L\n", f.waterIntake);
    printf("Sleep Hours: %.2f hrs\n", f.sleepHours);
    printf("Exercise Minutes: %d mins\n", f.exerciseMinutes);

    float net = f.caloriesConsumed - f.caloriesBurned;
    printf("Net Calories: %.2f kcal\n", net);

    if (net > 0)
        printf("Tip: You are in a calorie surplus.\n");
    else if (net < 0)
        printf("Tip: You are in a calorie deficit.\n");
    else
        printf("Tip: Calorie balance is perfect!\n");
}



// ---------------- SAVE FILE ----------------
void saveToFile(struct User u, struct Fitness f) {
    FILE *fp = fopen("fitness_log.txt", "a");

    if (fp == NULL) {
        printf("Error saving file!\n");
        return;
    }

    fprintf(fp, "Name: %s\n", u.name);
    fprintf(fp, "Steps: %d\n", f.steps);
    fprintf(fp, "Calories Consumed: %.2f\n", f.caloriesConsumed);
    fprintf(fp, "Calories Burned: %.2f\n", f.caloriesBurned);
 fprintf(fp, "Water: %.2f L\n", f.waterIntake);
    fprintf(fp, "Sleep: %.2f hrs\n", f.sleepHours);
    fprintf(fp, "Exercise: %d mins\n", f.exerciseMinutes);
    fprintf(fp, "-------------------\n");

    fclose(fp);
    printf("Saved successfully!\n");
}

// ---------------- VIEW HISTORY ----------------
void viewHistory() {
    FILE *fp = fopen("fitness_log.txt", "r");
    char ch;

    if (fp == NULL) {
        printf("No history found!\n");
        return;
    }

    printf("\n===== HISTORY =====\n");
    while ((ch = fgetc(fp)) != EOF) {
        putchar(ch);
    }

    fclose(fp);
}

// ---------------- RESET ----------------
void resetData(struct Fitness *f) {
    f->steps = 0;
    f->caloriesConsumed = 0;
    f->caloriesBurned = 0;
    f->waterIntake = 0;
    f->sleepHours = 0;
    f->exerciseMinutes = 0;

    printf("Data reset done!\n");
}

// ---------------- GOALS ----------------
void setGoals(int *stepGoal, float *waterGoal) {
    printf("Enter step goal: ");
    scanf("%d", stepGoal);

    printf("Enter water goal (L): ");
    scanf("%f", waterGoal);

    printf("Goals updated! Step goal: %d | Water goal: %.1f L\n", *stepGoal, *waterGoal);
}

// ---------------- CHECK GOALS ----------------
void checkGoals(struct Fitness f, int stepGoal, float waterGoal) {
    printf("\n===== GOAL PROGRESS =====\n");

    printf("Steps: %d / %d ", f.steps, stepGoal);
    if (f.steps >= stepGoal)
        printf("[ACHIEVED!]\n");
    else
        printf("(%d remaining)\n", stepGoal - f.steps);

    printf("Water: %.2f / %.2f L ", f.waterIntake, waterGoal);
    if (f.waterIntake >= waterGoal)
        printf("[ACHIEVED!]\n");
    else
        printf("(%.2f L remaining)\n", waterGoal - f.waterIntake);
}

// ---------------- WEEKLY STATS ----------------
void weeklyStats() {
    int weeklySteps[7] = {8000, 9000, 7500, 10000, 11000, 6000, 5000};
    const char *days[7] = {"Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"};
    int total = 0;

    printf("\n===== WEEKLY STATS =====\n");
    for (int i = 0; i < 7; i++) {
        printf("%s: %5d steps ", days[i], weeklySteps[i]);
        // Simple bar chart
        int bars = weeklySteps[i] / 1000;
        for (int j = 0; j < bars; j++) printf("|");
        printf("\n");
        total += weeklySteps[i];
    }
    printf("Total : %d steps\n", total);
    printf("Daily Avg: %d steps\n", total / 7);
}

// ---------------- LOGIN ----------------
void login() {
    char username[20], password[20];

    printf("Enter username: ");
    scanf("%s", username);

    printf("Enter password: ");
    scanf("%s", password);

    if (strcmp(username, "admin") == 0 && strcmp(password, "1234") == 0)
        printf("Login successful! Welcome, %s.\n", username);
    else {
        printf("Wrong username or password!\n");
        exit(0);
    }
}
// ---------------- MAIN ----------------
int main() {
    struct User user;
    struct Fitness fit;

    int choice;
    int stepGoal = 10000;
    float waterGoal = 2.5;

    printf("===== FITNESS TRACKER =====\n");
    login();

    // Initialize fitness data
    fit.steps = 0;
    fit.caloriesConsumed = 0;
    fit.caloriesBurned = 0;
    fit.waterIntake = 0;
    fit.sleepHours = 0;
    fit.exerciseMinutes = 0;

    printf("\n--- User Profile Setup ---\n");
    printf("Enter name: ");
    scanf(" %[^\n]", user.name);

    printf("Age: ");
    scanf("%d", &user.age);

    printf("Weight (kg): ");
    scanf("%f", &user.weight);

    printf("Height (m): ");
    scanf("%f", &user.height);

    printf("\nProfile saved! Hello, %s!\n", user.name);

    while (1) {
        printf("\n===== MENU =====\n");
        printf(" 1. Add Steps\n");
        printf(" 2. Add Calories Consumed\n");
        printf(" 3. Add Water Intake\n");
        printf(" 4. Add Sleep Hours\n");
        printf(" 5. Add Exercise Minutes\n");
        printf(" 6. Show Summary\n");
        printf(" 7. Save Data\n");
        printf(" 8. View History\n");
        printf(" 9. Reset Data\n");
        printf("10. Set Goals\n");
        printf("11. Check Goal Progress\n");
        printf("12. Weekly Stats\n");
        printf("13. Exit\n");

        printf("Choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1: {
                int s;
                printf("Enter steps: ");
                scanf("%d", &s);
                if (s < 0) { printf("Steps cannot be negative!\n"); break; }
                fit.steps += s;
                fit.caloriesBurned = calculateCaloriesBurned(fit.steps, user.weight);
                printf("Steps updated: %d total (%.2f kcal burned)\n", fit.steps, fit.caloriesBurned);
                break;
            }

            case 2: {
                float c;
                printf("Enter calories consumed (kcal): ");
                scanf("%f", &c);
                if (c < 0) { printf("Calories cannot be negative!\n"); break; }
                fit.caloriesConsumed += c;
                printf("Calories updated: %.2f kcal total\n", fit.caloriesConsumed);
                break;
            }

            case 3: {
                float w;
                printf("Enter water intake (L): ");
                scanf("%f", &w);
                if (w < 0) { printf("Water intake cannot be negative!\n"); break; }
                fit.waterIntake += w;
                printf("Water intake updated: %.2f L total\n", fit.waterIntake);
                break;
            }

            case 4: {
                float sleep;
                printf("Enter sleep hours: ");
                scanf("%f", &sleep);
                if (sleep < 0 || sleep > 24) { printf("Invalid sleep hours!\n"); break; }
                fit.sleepHours += sleep;
                printf("Sleep updated: %.2f hrs total\n", fit.sleepHours);
                break;
            }

            case 5: {
                int ex;
                printf("Enter exercise minutes: ");
                scanf("%d", &ex);
                if (ex < 0) { printf("Exercise minutes cannot be negative!\n"); break; }
                fit.exerciseMinutes += ex;
                printf("Exercise updated: %d mins total\n", fit.exerciseMinutes);
                break;
            }

            case 6:
                displaySummary(user, fit);
                break;

            case 7:
                saveToFile(user, fit);
                break;

            case 8:
                viewHistory();
                break;

            case 9:
                resetData(&fit);
                break;

            case 10:
                setGoals(&stepGoal, &waterGoal);
                break;

            case 11:
                checkGoals(fit, stepGoal, waterGoal);
                break;

            case 12:
                weeklyStats();
                break;

            case 13:
                printf("Goodbye, %s! Stay healthy!\n", user.name);
                return 0;

            default:
                printf("Invalid choice! Please enter 1-13.\n");
        }
    }

    return 0;
}
