#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// ---------------- USER STRUCT ----------------
struct User {
    char name[50];
    int age;
    float weight;
    float height;
};

// ---------------- FITNESS STRUCT ----------------
struct Fitness {
    int steps;
    float caloriesConsumed;
    float caloriesBurned;
    float waterIntake;
    float sleepHours;
    int exerciseMinutes;
};

// ---------------- FUNCTION DECLARATIONS ----------------
float calculateCaloriesBurned(int steps, float weight);
float calculateBMI(float weight, float height);
void displayBMICategory(float bmi);
void displaySummary(struct User u, struct Fitness f);
void saveToFile(struct User u, struct Fitness f);
void viewHistory();
void resetData(struct Fitness *f);
void setGoals(int *stepGoal, float *waterGoal);
void weeklyStats();
void login();
void checkGoals(struct Fitness f, int stepGoal, float waterGoal);

// ---------------- CALCULATE CALORIES ----------------
float calculateCaloriesBurned(int steps, float weight) {
    return steps * 0.04 * (weight / 70.0);
}

// ---------------- BMI ----------------
float calculateBMI(float weight, float height) {
    if (height <= 0) return 0;
    return weight / (height * height);
}

// ---------------- BMI CATEGORY ----------------
void displayBMICategory(float bmi) {
    printf("BMI: %.2f\n", bmi);
if (bmi < 18.5)
        printf("Category: Underweight\n");
    else if (bmi < 25)
        printf("Category: Normal\n");
    else if (bmi < 30)
        printf("Category: Overweight\n");
    else
        printf("Category: Obese\n");
}


// ---------------- SUMMARY ----------------
void displaySummary(struct User u, struct Fitness f) {
    printf("\n===== SUMMARY =====\n");
    printf("Name: %s\n", u.name);
    printf("Age: %d\n", u.age);

    float bmi = calculateBMI(u.weight, u.height);
    displayBMICategory(bmi);

    printf("Steps: %d\n", f.steps);
    printf("Calories Consumed: %.2f kcal\n", f.caloriesConsumed);
    printf("Calories Burned: %.2f kcal\n", f.caloriesBurned);
    printf("Water Intake: %.2f L\n", f.waterIntake);
    printf("Sleep Hours: %.2f hrs\n", f.sleepHours);
    printf("Exercise Minutes: %d mins\n", f.exerciseMinutes);

    float net = f.caloriesConsumed - f.caloriesBurned;
    printf("Net Calories: %.2f kcal\n", net);

    if (net > 0)
        printf("Tip: You are in a calorie surplus.\n");
    else if (net < 0)
        printf("Tip: You are in a calorie deficit.\n");
    else
        printf("Tip: Calorie balance is perfect!\n");
}



// ---------------- SAVE FILE ----------------
void saveToFile(struct User u, struct Fitness f) {
    FILE *fp = fopen("fitness_log.txt", "a");

    if (fp == NULL) {
        printf("Error saving file!\n");
        return;
    }

    fprintf(fp, "Name: %s\n", u.name);
    fprintf(fp, "Steps: %d\n", f.steps);
    fprintf(fp, "Calories Consumed: %.2f\n", f.caloriesConsumed);
    fprintf(fp, "Calories Burned: %.2f\n", f.caloriesBurned);
 fprintf(fp, "Water: %.2f L\n", f.waterIntake);
    fprintf(fp, "Sleep: %.2f hrs\n", f.sleepHours);
    fprintf(fp, "Exercise: %d mins\n", f.exerciseMinutes);
    fprintf(fp, "-------------------\n");

    fclose(fp);
    printf("Saved successfully!\n");
}
